{
  "name": "capsule",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Version control for a running backend — freeze, restore, and diff backend state.",
  "scripts": {
    "capsule": "tsx src/cli/index.ts",
    "mcp": "tsx src/mcp/index.ts",
    "api": "tsx src/api/index.ts",
    "demo": "tsx demo/run-demo.ts",
    "demo:insforge": "tsx demo/insforge-crash.ts",
    "demo:reset": "tsx demo/insforge-reset.ts",
    "dev:dashboard": "vite dashboard",
    "build": "vite build dashboard",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/sora": "^5.2.8",
    "@insforge/sdk": "^1.3.1",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.0.0",
    "gsap": "^3.15.0",
    "openai": "^6.42.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
