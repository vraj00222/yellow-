# Copy to .env and fill in. .env is gitignored — never commit real keys.
# Only needed when you connect a real InsForge backend.

CAPSULE_ADAPTER=insforge

# Your InsForge project base URL (InsForge dashboard, or `npx @insforge/cli current`)
#   e.g. https://your-app.insforge.app
INSFORGE_URL=

# Project ADMIN API key (starts with uak_). Server-side only — keep it secret.
INSFORGE_API_KEY=

# Storage bucket Capsule writes snapshots into (create it once in the dashboard).
CAPSULE_BUCKET=capsule

# Comma-separated tables to snapshot. OPTIONAL — omit to auto-discover all
# tables via GET /api/database/tables. Set it to scope snapshots in production.
CAPSULE_TABLES=products,carts,users

# Schema tag — bump this when you run a migration so diffs flag schema drift.
CAPSULE_SCHEMA_VERSION=1

REPLICAS_API_KEY=sk_replicas_aaGgb7Q5UqA0mrBkPQt3GKp5a2kfZLphNSzHYxybq90
REPLICAS_AGENT_ID=4712b33a-ed76-49cb-b57f-db807ee09292